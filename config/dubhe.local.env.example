# Dubhe local runtime configuration.
# Copy to config/dubhe.local.env or double-click Configure-Dubhe.cmd.
# Lines starting with # are ignored. Remove "# " before KEY=VALUE to enable.

# AI model router. Supports OpenAI-compatible /chat/completions services.
# DUBHE_LLM_MODEL=gpt-4.1-mini
# DUBHE_LLM_API_KEY=replace-with-your-api-key
# DUBHE_LLM_BASE_URL=https://api.openai.com/v1
# DUBHE_LLM_PROVIDER=openai_compatible
# DUBHE_LLM_TIMEOUT_SECONDS=20
# DUBHE_LLM_MAX_TOKENS=900
# DUBHE_LLM_TEMPERATURE=0.2

# Licensed / public financial news sources.
# FINNHUB_API_KEY=replace-with-your-finnhub-key
# ALPHA_VANTAGE_API_KEY=replace-with-your-alpha-vantage-key
# DUBHE_SEC_USER_AGENT=Dubhe/0.1 your-email@example.com

# Optional paper broker adapter. Keep simulated_paper for local demos.
# DUBHE_PAPER_BROKER=simulated_paper
# ALPACA_PAPER_API_KEY_ID=replace-with-your-alpaca-paper-key-id
# ALPACA_PAPER_SECRET_KEY=replace-with-your-alpaca-paper-secret
# ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets

# Optional local MFA. Double-click Setup-Dubhe-MFA.cmd to generate TOTP values.
# DUBHE_LOCAL_MFA_MODE=placeholder
# DUBHE_LOCAL_MFA_CODE=000000
# DUBHE_LOCAL_TOTP_SECRET=replace-with-generated-base32-secret
# DUBHE_LOCAL_TOTP_ISSUER=Dubhe
# DUBHE_LOCAL_TOTP_ACCOUNT=local-admin

# Optional persistent Core database override.
# DUBHE_CORE_DB_PATH=D:\dubhe-data\dubhe-core.sqlite
