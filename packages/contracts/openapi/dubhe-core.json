          },
          "strategy_version_id": {
            "type": "string",
            "minLength": 1,
            "title": "Strategy Version Id"
          },
          "market": {
            "$ref": "#/components/schemas/Market"
          },
          "symbol": {
            "type": "string",
            "minLength": 1,
