          },
          "quantity": {
            "type": "number",
            "exclusiveMinimum": 0.0,
            "title": "Quantity"
          },
          "estimated_price": {
            "type": "number",
            "exclusiveMinimum": 0.0,
            "title": "Estimated Price"
          },
          "limit_price": {
            "anyOf": [
              {
                "type": "number",
                "exclusiveMinimum": 0.0
              },
              {
                "type": "null"
              }
