            "title": "Limit Price"
          },
          "currency": {
            "type": "string",
            "maxLength": 3,
            "minLength": 3,
            "title": "Currency"
          },
          "created_by": {
            "type": "string",
            "enum": [
              "ai",
              "strategy",
              "user"
