        "type": "object",
        "required": [
          "news_event_id",
          "summary_zh",
          "sentiment",
          "impact_score",
          "source_refs",
          "confidence"
        ],
        "title": "NewsAnalysis"
      },
      "NewsEvent": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "provider": {
            "type": "string",
            "minLength": 1,
            "title": "Provider"
          },
          "provider_event_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Provider Event Id"
          },
          "source_name": {
            "type": "string",
            "minLength": 1,
            "title": "Source Name"
          },
          "market_scope": {
            "items": {
              "$ref": "#/components/schemas/Market"
            },
            "type": "array",
            "title": "Market Scope"
          },
          "language": {
            "type": "string",
            "title": "Language",
            "default": "zh-CN"
          },
          "title_original": {
            "type": "string",
            "minLength": 1,
            "title": "Title Original"
          },
          "title_zh": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Title Zh"
          },
          "body_original_ref": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Body Original Ref"
          },
          "body_zh_ref": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Body Zh Ref"
          },
          "published_at": {
            "type": "string",
            "format": "date-time",
            "title": "Published At"
          },
          "received_at": {
            "type": "string",
            "format": "date-time",
            "title": "Received At"
          },
          "url": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Url"
          },
          "tickers": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Tickers"
          },
          "entities": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Entities"
          },
          "event_type": {
            "type": "string",
            "title": "Event Type",
            "default": "unknown"
          },
          "authority_score": {
            "type": "number",
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Authority Score",
            "default": 0.5
