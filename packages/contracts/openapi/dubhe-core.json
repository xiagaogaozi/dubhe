          "rationale_zh": {
            "type": "string",
            "minLength": 1,
            "title": "Rationale Zh"
          },
          "source_refs": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Source Refs"
          }
        },
        "type": "object",
        "required": [
          "account_id",
          "strategy_version_id",
          "market",
          "symbol",
          "side",
          "quantity",
          "estimated_price",
          "currency",
          "created_by",
          "rationale_zh"
        ],
        "title": "OrderIntent"
      },
      "OrderSide": {
        "type": "string",
