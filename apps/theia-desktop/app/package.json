{
  "private": true,
  "name": "@dubhe/theia-desktop-app",
  "version": "0.1.0",
  "description": "Dubhe Desktop Electron application composed with Eclipse Theia.",
  "author": "Dubhe Project",
  "main": "lib/backend/electron-main.js",
  "dependencies": {
    "@dubhe/theia-extension": "0.1.0",
    "@theia/callhierarchy": "1.73.1",
    "@theia/core": "1.73.1",
    "@theia/editor": "1.73.1",
    "@theia/electron": "1.73.1",
    "@theia/filesystem": "1.73.1",
    "@theia/markers": "1.73.1",
    "@theia/messages": "1.73.1",
    "@theia/monaco": "1.73.1",
    "@theia/navigator": "1.73.1",
    "@theia/outline-view": "1.73.1",
    "@theia/preferences": "1.73.1",
    "@theia/process": "1.73.1",
    "@theia/search-in-workspace": "1.73.1",
    "@theia/terminal": "1.73.1",
    "@theia/workspace": "1.73.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@theia/cli": "1.73.1",
    "electron": "39.8.7",
    "electron-builder": "^26.15.3",
    "typescript": "~5.8.3"
  },
  "scripts": {
    "bundle": "yarn rebuild && theia build --mode development",
    "dist:mac": "yarn bundle && electron-builder --mac dmg zip",
    "dist:mac:arm64": "yarn bundle && electron-builder --mac dmg zip --arm64",
    "dist:mac:x64": "yarn bundle && electron-builder --mac dmg zip --x64",
    "dist:windows": "yarn bundle && electron-builder --win nsis portable",
    "rebuild": "theia rebuild:electron --cacheRoot ../.theia-cache",
    "start": "theia start --plugins=local-dir:plugins",
    "watch": "yarn rebuild && theia build --watch --mode development",
    "package:electron": "yarn bundle && electron-builder --dir"
  },
  "theia": {
    "target": "electron"
  }
}
